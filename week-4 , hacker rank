# Read number of words
n = int(input().strip())

word_count = {}
order = []

for _ in range(n):
    word = input().strip()
    if word not in word_count:
        word_count[word] = 1
        order.append(word)
    else:
        word_count[word] += 1

# Output number of distinct words
print(len(order))

# Output occurrences in order of first appearance
print(" ".join(str(word_count[word]) for word in order))
